{% block sw_content_creator_batch %}
<sw-page class="sw-content-creator-batch">
    <template #smart-bar-actions>
        <sw-button @click="$router.push({ name: 'sw.content.creator.tools' })">
            {{ $tc('sw-content-creator.tools.navTitle') }}
        </sw-button>
        <sw-button @click="$router.push({ name: 'sw.content.creator.settings' })">
            {{ $tc('sw-content-creator.settings.navTitle') }}
        </sw-button>
        <sw-button @click="$router.push({ name: 'sw.content.creator.generator' })">
            {{ $tc('sw-content-creator.batch.toGenerator') }}
        </sw-button>
    </template>

    <template #content>
        <sw-card-view>
            {% block sw_content_creator_batch_config %}
            <sw-card :title="$tc('sw-content-creator.batch.title')">
                <div style="display:flex; gap:16px;">
                    <sw-single-select
                        :label="$tc('sw-content-creator.batch.entityType')"
                        :options="entityTypeOptions"
                        :value="entityType"
                        @update:value="onEntityTypeChange">
                    </sw-single-select>

                    <sw-single-select
                        :label="$tc('sw-content-creator.generator.language')"
                        :helpText="$tc('sw-content-creator.batch.languageHelp')"
                        :options="langOptions"
                        :value="lang"
                        @update:value="onLangChange">
                    </sw-single-select>

                    <sw-single-select
                        :label="$tc('sw-content-creator.generator.mode')"
                        :helpText="$tc('sw-content-creator.batch.modeHelp')"
                        :options="modeOptions"
                        :value="mode"
                        @update:value="(val) => { mode = val; }">
                    </sw-single-select>
                </div>
            </sw-card>
            {% endblock %}

            {% block sw_content_creator_batch_worklist %}
            <sw-card :title="$tc('sw-content-creator.gaps.title')">
                <p style="color:#758ca3; font-size:13px; margin-bottom:12px;">
                    {{ $tc('sw-content-creator.gaps.hint') }}
                </p>
                <div style="display:flex; gap:8px; flex-wrap:wrap;">
                    <sw-button :isLoading="gapBusy" @click="scanGaps">
                        {{ $tc('sw-content-creator.gaps.scan') }}
                    </sw-button>
                    <sw-button :isLoading="reportBusy" @click="runQualityReport">
                        {{ $tc('sw-content-creator.gaps.report') }}
                    </sw-button>
                    <sw-button :isLoading="freshnessBusy" @click="scanFreshness">
                        {{ $tc('sw-content-creator.freshness.scan') }}
                    </sw-button>
                </div>
                <p v-if="reportProgress" style="margin-top:8px; color:#758ca3;">
                    {{ $tc('sw-content-creator.gaps.reportProgress', { scanned: reportProgress.scanned }, reportProgress.scanned) }}
                </p>

                <template v-if="gapResult">
                    <sw-alert
                        v-if="!Object.values(gapResult).some((g) => g.count > 0)"
                        variant="success"
                        style="margin-top:12px;">
                        {{ $tc('sw-content-creator.gaps.clean') }}
                    </sw-alert>
                    <div v-for="(gap, key) in gapResult" :key="key" style="display:flex; gap:12px; align-items:center; padding:6px 0;">
                        <span style="flex:1;">{{ gapLabel(key) }}: <strong>{{ gap.count }}</strong></span>
                        <sw-button v-if="gap.count > 0" size="small" @click="useGapSelection(key)">
                            {{ $tc('sw-content-creator.gaps.use') }}
                        </sw-button>
                    </div>
                </template>

                <template v-if="report">
                    <sw-alert v-if="!report.total" variant="success" style="margin-top:12px;">
                        {{ $tc('sw-content-creator.gaps.reportClean', { scanned: report.scanned }, report.scanned) }}
                    </sw-alert>
                    <template v-else>
                        <p style="margin-top:12px; font-weight:600;">
                            {{ $tc('sw-content-creator.gaps.reportResult', { total: report.total, scanned: report.scanned }, report.total) }}
                        </p>
                        <div v-for="item in report.items" :key="item.id" style="display:flex; gap:12px; padding:2px 0; font-size:13px; align-items:center;">
                            <span style="width:60px; font-weight:600;">{{ item.score }}</span>
                            <span style="flex:1;">{{ item.name }}</span>
                            <span style="color:#758ca3;">{{ item.level }}</span>
                            <sw-button size="small" @click="openInGenerator(item.id)">
                                {{ $tc('sw-content-creator.gaps.fixNow') }}
                            </sw-button>
                        </div>
                        <sw-button v-if="report.items.length" variant="primary" style="margin-top:8px;" @click="useWorstSelection">
                            {{ $tc('sw-content-creator.gaps.useWorst') }}
                        </sw-button>
                    </template>
                </template>

                <template v-if="freshnessResult">
                    <sw-alert
                        v-if="!freshnessResult.changedSince.length && !freshnessResult.aging.length"
                        variant="success"
                        style="margin-top:12px;">
                        {{ $tc('sw-content-creator.freshness.clean') }}
                    </sw-alert>
                    <template v-else>
                        <p style="margin-top:12px; font-weight:600;">{{ $tc('sw-content-creator.freshness.changed') }} ({{ freshnessResult.changedSince.length }})</p>
                        <div v-for="item in freshnessResult.changedSince.slice(0, 25)" :key="'f-' + item.id" style="font-size:13px; padding:1px 0;">
                            {{ item.name }} <span style="color:#758ca3;">({{ $tc('sw-content-creator.freshness.generatedAt') }} {{ new Date(item.generatedAt).toLocaleDateString() }})</span>
                        </div>
                        <p style="margin-top:8px; font-weight:600;">{{ $tc('sw-content-creator.freshness.aging') }} ({{ freshnessResult.aging.length }})</p>
                        <div v-for="item in freshnessResult.aging.slice(0, 25)" :key="'a-' + item.id" style="font-size:13px; padding:1px 0;">
                            {{ item.name }} <span style="color:#758ca3;">({{ new Date(item.generatedAt).toLocaleDateString() }})</span>
                        </div>
                        <sw-button variant="primary" style="margin-top:8px;" @click="useFreshnessSelection">
                            {{ $tc('sw-content-creator.freshness.use') }}
                        </sw-button>
                    </template>
                </template>
            </sw-card>
            {% endblock %}

            {% block sw_content_creator_batch_start %}
            <sw-card :title="$tc('sw-content-creator.batch.startCard')">
                <sw-entity-single-select
                    v-if="entityType === 'category'"
                    entity="sales_channel"
                    :criteria="storefrontChannelCriteria"
                    :label="$tc('sw-content-creator.generator.channelFilter')"
                    :helpText="$tc('sw-content-creator.generator.channelFilterHelp')"
                    :value="categorySalesChannelId"
                    @update:value="onCategoryChannelChange">
                </sw-entity-single-select>

                <sw-entity-multi-id-select
                    class="sw-content-creator-batch__ids"
                    :repository="repository"
                    :context="languageContext"
                    :criteria="entityCriteria"
                    :label="$tc('sw-content-creator.batch.selectEntities')"
                    :value="selectedIds"
                    @update:value="onIdsChange">
                </sw-entity-multi-id-select>

                <div class="sw-content-creator-batch__types" style="margin-top:16px;">
                    <label style="font-weight:600;">{{ $tc('sw-content-creator.batch.types') }}</label>
                    <sw-checkbox-field
                        v-for="t in typeOptions"
                        :key="t"
                        :label="typeLabel(t)"
                        :value="selectedTypes.includes(t)"
                        @update:value="(val) => setType(t, val)">
                    </sw-checkbox-field>
                </div>

                <sw-switch-field
                    style="margin-top:8px;"
                    :label="$tc('sw-content-creator.batch.dryRun')"
                    :helpText="$tc('sw-content-creator.batch.dryRunHelp')"
                    :value="dryRun"
                    @update:value="(v) => { dryRun = v; }">
                </sw-switch-field>

                <sw-button
                    variant="primary"
                    style="margin-top:8px;"
                    :isLoading="isStarting"
                    :disabled="isRunning"
                    @click="startBatch">
                    {{ dryRun ? $tc('sw-content-creator.batch.startDryRun') : $tc('sw-content-creator.batch.start') }}
                </sw-button>

                <sw-alert variant="info" style="margin-top:16px;">
                    {{ $tc('sw-content-creator.batch.workerHint') }}
                </sw-alert>
            </sw-card>
            {% endblock %}

            {% block sw_content_creator_batch_progress %}
            <sw-card v-if="job" :title="$tc('sw-content-creator.batch.progress')">
                <sw-progress-bar :value="progressDone" :maxValue="job.total"></sw-progress-bar>
                <p style="margin-top:12px;">
                    {{ progressDone }} / {{ job.total }} ({{ progressPercent }}%)
                    – Status: {{ job.status }},
                    {{ $tc('sw-content-creator.batch.written') }}: {{ job.processed }},
                    {{ $tc('sw-content-creator.batch.rejected') }}: {{ job.rejected || 0 }},
                    {{ $tc('sw-content-creator.batch.failed') }}: {{ job.failed }}
                    <span v-if="job.inputTokens || job.outputTokens">
                        – {{ (job.inputTokens || 0) + (job.outputTokens || 0) }} Tokens<span v-if="jobCost"> · {{ jobCost }}</span>
                    </span>
                </p>
                <sw-alert v-if="workerStalled" variant="error" style="margin-top:8px;">
                    {{ $tc('sw-content-creator.batch.workerStalled') }}
                </sw-alert>
                <sw-alert v-if="(job.rejected || 0) > 0" variant="warning" style="margin-top:8px;">
                    {{ $tc('sw-content-creator.batch.rejectedHint') }}
                </sw-alert>
                <template v-if="!isRunning && job.issues && job.issues.length">
                    <p style="margin-top:12px; font-weight:600;">{{ $tc('sw-content-creator.batch.issuesTitle') }}</p>
                    <div style="max-height:260px; overflow-y:auto;">
                        <div v-for="(issue, idx) in job.issues" :key="idx" style="font-size:12px; padding:2px 0; color:#61300d;">
                            <strong>{{ typeLabel(issue.type) }}</strong> ({{ issue.entityId.substring(0, 8) }}…): {{ issue.reason }}
                        </div>
                    </div>
                </template>
                <template v-if="job.dryRun && !isRunning && !job.committed">
                    <sw-alert variant="info" style="margin-top:8px;">
                        {{ $tc('sw-content-creator.batch.dryRunDone', { passed: job.pendingResults || 0 }, job.pendingResults || 0) }}
                    </sw-alert>
                    <sw-button
                        v-if="(job.pendingResults || 0) > 0"
                        variant="primary"
                        style="margin-top:8px;"
                        :isLoading="isCommitting"
                        @click="commitDryRun">
                        {{ $tc('sw-content-creator.batch.commit', { passed: job.pendingResults || 0 }, job.pendingResults || 0) }}
                    </sw-button>
                </template>
            </sw-card>
            {% endblock %}
        </sw-card-view>
    </template>
</sw-page>
{% endblock %}
