{% block sw_content_creator_settings %}
<sw-page class="sw-content-creator-settings">
    <template #smart-bar-actions>
        <sw-button @click="$router.push({ name: 'sw.content.creator.generator' })">
            {{ $tc('sw-content-creator.settings.toGenerator') }}
        </sw-button>
        <sw-button variant="primary" :isLoading="isSaving" @click="save">
            {{ $tc('sw-content-creator.settings.save') }}
        </sw-button>
    </template>

    <template #content>
        <sw-card-view>
            {% block sw_content_creator_settings_provider %}
            <sw-card :title="$tc('sw-content-creator.settings.providerCard')" :isLoading="isLoading">
                <sw-single-select
                    :label="$tc('sw-content-creator.settings.provider')"
                    :helpText="$tc('sw-content-creator.settings.providerHelp')"
                    :options="providerOptions"
                    :value="get('provider')"
                    @update:value="(v) => set('provider', v)">
                </sw-single-select>

                <template v-if="get('provider') === 'openai'">
                    <sw-password-field
                        autocomplete="new-password"
                        name="cc-openai-api-key"
                        :label="$tc('sw-content-creator.settings.openaiKey')"
                        :value="get('openaiApiKey')"
                        @update:value="(v) => set('openaiApiKey', v)">
                    </sw-password-field>
                    <sw-text-field
                        :label="$tc('sw-content-creator.settings.openaiModel')"
                        :helpText="$tc('sw-content-creator.settings.openaiModelHelp')"
                        :value="get('openaiModel')"
                        @update:value="(v) => set('openaiModel', v)">
                    </sw-text-field>
                </template>
                <template v-else>
                    <sw-password-field
                        autocomplete="new-password"
                        name="cc-anthropic-api-key"
                        :label="$tc('sw-content-creator.settings.anthropicKey')"
                        :helpText="$tc('sw-content-creator.settings.anthropicKeyHelp')"
                        :value="get('anthropicApiKey')"
                        @update:value="(v) => set('anthropicApiKey', v)">
                    </sw-password-field>
                    <sw-single-select
                        :label="$tc('sw-content-creator.settings.anthropicModel')"
                        :options="anthropicModelOptions"
                        :value="get('anthropicModel')"
                        @update:value="(v) => set('anthropicModel', v)">
                    </sw-single-select>
                    <sw-single-select
                        :label="$tc('sw-content-creator.settings.batchModel')"
                        :helpText="$tc('sw-content-creator.settings.batchModelHelp')"
                        :options="batchModelOptions"
                        :value="get('batchModel')"
                        @update:value="(v) => set('batchModel', v)">
                    </sw-single-select>
                </template>

                <div style="margin-top:16px;">
                    <sw-button :isLoading="isTesting" @click="testConnection">
                        {{ $tc('sw-content-creator.settings.testButton') }}
                    </sw-button>
                    <span style="margin-left:8px; color:#758ca3; font-size:12px;">
                        {{ $tc('sw-content-creator.settings.testHint') }}
                    </span>
                </div>
            </sw-card>
            {% endblock %}

            {% block sw_content_creator_settings_automation %}
            <sw-card :title="$tc('sw-content-creator.settings.industryCard')" :isLoading="isLoading">
                <p style="color:#758ca3; font-size:13px; margin-bottom:12px;">
                    {{ $tc('sw-content-creator.settings.industryIntro') }}
                </p>
                <sw-textarea-field
                    :label="$tc('sw-content-creator.settings.industryKeywordsDe')"
                    :helpText="$tc('sw-content-creator.settings.industryEmptyHint')"
                    :placeholder="$tc('sw-content-creator.settings.industryDefaultPlaceholder')"
                    :value="config['ContentCreator.config.industryKeywordsDe']"
                    @update:value="(v) => { config['ContentCreator.config.industryKeywordsDe'] = v; }">
                </sw-textarea-field>
                <sw-textarea-field
                    :label="$tc('sw-content-creator.settings.industryKeywordsEn')"
                    :helpText="$tc('sw-content-creator.settings.industryEmptyHint')"
                    :placeholder="$tc('sw-content-creator.settings.industryDefaultPlaceholder')"
                    :value="config['ContentCreator.config.industryKeywordsEn']"
                    @update:value="(v) => { config['ContentCreator.config.industryKeywordsEn'] = v; }">
                </sw-textarea-field>
                <sw-textarea-field
                    :label="$tc('sw-content-creator.settings.industryQaDe')"
                    :helpText="$tc('sw-content-creator.settings.industryQaHelp')"
                    :placeholder="$tc('sw-content-creator.settings.industryDefaultPlaceholder')"
                    :value="config['ContentCreator.config.industryQaDe']"
                    @update:value="(v) => { config['ContentCreator.config.industryQaDe'] = v; }">
                </sw-textarea-field>
                <sw-textarea-field
                    :label="$tc('sw-content-creator.settings.industryQaEn')"
                    :helpText="$tc('sw-content-creator.settings.industryQaHelp')"
                    :placeholder="$tc('sw-content-creator.settings.industryDefaultPlaceholder')"
                    :value="config['ContentCreator.config.industryQaEn']"
                    @update:value="(v) => { config['ContentCreator.config.industryQaEn'] = v; }">
                </sw-textarea-field>
            </sw-card>

            <sw-card :title="$tc('sw-content-creator.settings.checklistCard')" :isLoading="isLoading">
                <div v-for="item in startupChecklist" :key="item.label" style="display:flex; gap:8px; padding:3px 0; font-size:13px; align-items:center;">
                    <span :style="{ color: item.ok ? '#37a04a' : '#de294c', fontWeight: 700 }">{{ item.ok ? '✓' : '✗' }}</span>
                    <span>{{ item.label }}</span>
                    <span v-if="item.hint && !item.ok" style="color:#758ca3;">— {{ item.hint }}</span>
                </div>
            </sw-card>

            <sw-card :title="$tc('sw-content-creator.settings.redirectCard')" :isLoading="isLoading">
                <sw-text-field
                    :label="$tc('sw-content-creator.settings.redirectFile')"
                    :helpText="$tc('sw-content-creator.settings.redirectFileHelp')"
                    :value="config['ContentCreator.config.redirectFile']"
                    @update:value="(v) => { config['ContentCreator.config.redirectFile'] = v; }">
                </sw-text-field>
                <sw-alert variant="info">
                    {{ $tc('sw-content-creator.settings.redirectSetup') }}
                </sw-alert>
            </sw-card>

            <sw-card :title="$tc('sw-content-creator.settings.usageCard')" :isLoading="isLoading">
                <p style="color:#758ca3; font-size:13px; margin-bottom:12px;">
                    {{ $tc('sw-content-creator.settings.usageHint') }}
                </p>
                <p v-if="!usageRows.length" style="color:#758ca3;">{{ $tc('sw-content-creator.settings.usageEmpty') }}</p>
                <div v-else>
                    <div style="display:flex; gap:12px; font-weight:600; padding:4px 0; border-bottom:1px solid #e5e9f0;">
                        <span style="width:70px;">{{ $tc('sw-content-creator.settings.usageMonth') }}</span>
                        <span style="width:80px;">Provider</span>
                        <span style="flex:1;">Modell</span>
                        <span style="width:90px; text-align:right;">Requests</span>
                        <span style="width:110px; text-align:right;">Tokens in</span>
                        <span style="width:110px; text-align:right;">Tokens out</span>
                        <span style="width:80px; text-align:right;">~Kosten</span>
                    </div>
                    <div v-for="row in usageRows" :key="row.month + row.provider + row.model" style="display:flex; gap:12px; padding:4px 0; font-size:13px;">
                        <span style="width:70px;">{{ row.month }}</span>
                        <span style="width:80px;">{{ row.provider }}</span>
                        <span style="flex:1;">{{ row.model }}</span>
                        <span style="width:90px; text-align:right;">{{ row.requests }}</span>
                        <span style="width:110px; text-align:right;">{{ Number(row.inputTokens).toLocaleString() }}</span>
                        <span style="width:110px; text-align:right;">{{ Number(row.outputTokens).toLocaleString() }}</span>
                        <span style="width:80px; text-align:right;">{{ usageCost(row) }}</span>
                    </div>
                </div>
            </sw-card>

            <sw-card :title="$tc('sw-content-creator.settings.automationCard')" :isLoading="isLoading">
                <sw-switch-field
                    :label="$tc('sw-content-creator.settings.dailyFill')"
                    :value="get('dailyFillEnabled')"
                    @update:value="(v) => set('dailyFillEnabled', v)">
                </sw-switch-field>
                <sw-number-field
                    :label="$tc('sw-content-creator.settings.dailyFillLimit')"
                    :value="get('dailyFillLimit')"
                    @update:value="(v) => set('dailyFillLimit', v)">
                </sw-number-field>
            </sw-card>
            {% endblock %}

            {% block sw_content_creator_settings_quality %}
            <sw-card :title="$tc('sw-content-creator.settings.qualityCard')" :isLoading="isLoading">
                <sw-number-field
                    :label="$tc('sw-content-creator.settings.qualityMaxScore')"
                    :helpText="$tc('sw-content-creator.settings.qualityMaxScoreHelp')"
                    :value="get('qualityMaxScore')"
                    @update:value="(v) => set('qualityMaxScore', v)">
                </sw-number-field>
                <sw-number-field
                    :label="$tc('sw-content-creator.settings.qualityMaxRetries')"
                    :helpText="$tc('sw-content-creator.settings.qualityMaxRetriesHelp')"
                    :value="get('qualityMaxRetries')"
                    @update:value="(v) => set('qualityMaxRetries', v)">
                </sw-number-field>
                <sw-textarea-field
                    :label="$tc('sw-content-creator.settings.qualityWhitelist')"
                    :helpText="$tc('sw-content-creator.settings.qualityWhitelistHelp')"
                    :value="get('qualityWhitelist')"
                    @update:value="(v) => set('qualityWhitelist', v)">
                </sw-textarea-field>
                <sw-alert variant="info">
                    {{ $tc('sw-content-creator.settings.qualityHint') }}
                </sw-alert>
            </sw-card>
            {% endblock %}

            {% block sw_content_creator_settings_text %}
            <sw-card :title="$tc('sw-content-creator.settings.textCard')" :isLoading="isLoading">
                <sw-switch-field
                    :label="$tc('sw-content-creator.settings.animalProfile')"
                    :helpText="$tc('sw-content-creator.settings.animalProfileHelp')"
                    :value="get('includeAnimalProfile')"
                    @update:value="(v) => set('includeAnimalProfile', v)">
                </sw-switch-field>
                <sw-switch-field
                    :label="$tc('sw-content-creator.settings.funFact')"
                    :helpText="$tc('sw-content-creator.settings.funFactHelp')"
                    :value="get('includeFunFact')"
                    @update:value="(v) => set('includeFunFact', v)">
                </sw-switch-field>
                <sw-switch-field
                    :label="$tc('sw-content-creator.settings.research')"
                    :helpText="$tc('sw-content-creator.settings.researchHelp')"
                    :value="get('researchEnabled')"
                    @update:value="(v) => set('researchEnabled', v)">
                </sw-switch-field>
            </sw-card>
            {% endblock %}
        </sw-card-view>
    </template>
</sw-page>
{% endblock %}
